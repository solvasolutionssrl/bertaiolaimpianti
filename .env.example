# =====================================================================
# impiantiXplus — variabili ambiente (copia in .env.local per dev)
# =====================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TENANT_DEFAULT=bertaiola

# ---- Supabase (region Frankfurt EU) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
# --- variabili usate dalle Edge Functions (Deno) ---
# Su Supabase Cloud queste sono auto-injected; in `supabase functions serve` locale
# vanno passate via --env-file.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key

# ---- Edge Functions secrets ----
# Shared secret per il webhook DB → notify-event e per gli scheduled triggers
NOTIFY_WEBHOOK_SECRET=replace-with-random-32-bytes
# Shared secret per /onboard-tenant (richiesto come header `x-admin-secret`)
ONBOARDING_ADMIN_SECRET=replace-with-random-32-bytes
# From per email transactional in uscita
RESEND_FROM=impiantiXplus <notify@impiantixplus.it>

# ---- Anthropic Claude (per AI naming via Haiku) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI (Whisper transcription per Voice → Pre-commessa) ----
# Se assente o = "placeholder" il flusso /api/voice/extract gira in
# modalità preview (transcript fake plausibile, niente chiamata HTTP).
OPENAI_API_KEY=placeholder

# ---- Resend (email transactional outbound + inbound parsing) ----
RESEND_API_KEY=re_...
RESEND_INBOUND_SECRET=replace-with-webhook-secret

# ---- Storage provider (TBD per CLAUDE.md, default supabase per dev) ----
# Valori validi: supabase | nextcloud
STORAGE_PROVIDER=supabase

# ---- Nextcloud / Hetzner Storage Share (se STORAGE_PROVIDER=nextcloud) ----
NEXTCLOUD_BASE_URL=https://cloud.bertaiolaimpianti.example
NEXTCLOUD_USER=service-impiantixplus
NEXTCLOUD_APP_PASSWORD=replace-with-app-password

# ---- Web Push (VAPID) ----
VAPID_PUBLIC_KEY=replace-with-vapid-public
VAPID_PRIVATE_KEY=replace-with-vapid-private
VAPID_SUBJECT=mailto:ops@solva.example

# ---- Freshdesk migration (one-time) ----
FRESHDESK_API_KEY=
FRESHDESK_DOMAIN=bertaiolaimpianti
