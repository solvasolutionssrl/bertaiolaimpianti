{
  "name": "impiantixplus",
  "version": "0.1.0",
  "private": true,
  "description": "impiantiXplus — SOLVA SaaS multitenant per gestione commesse impiantistiche (pilot tenant: Bertaiola Impianti)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/api/src/types/database.generated.ts",
    "migrate:freshdesk": "tsx scripts/migrate-freshdesk.ts"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
