{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ANTHROPIC_API_KEY",
    "RESEND_API_KEY",
    "STORAGE_PROVIDER",
    "NEXTCLOUD_BASE_URL",
    "NEXTCLOUD_USER",
    "NEXTCLOUD_APP_PASSWORD",
    "VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_TENANT_DEFAULT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
